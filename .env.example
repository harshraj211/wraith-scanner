# Wraith local configuration template
# Copy this file to .env for local development. Do not commit real secrets.

# Flask API binding
SCANNER_HOST=127.0.0.1
SCANNER_PORT=5001
SCANNER_DEBUG=false

# Storage
WRAITH_DB_PATH=reports/wraith.sqlite3
WRAITH_HOME=
WRAITH_TOOLS_DIR=

# Frontend / desktop launcher
WRAITH_FRONTEND_BUILD=scanner-terminal/build
WRAITH_BROWSER_PROFILE_DIR=

# Optional intelligence and integrations
OPENAI_API_KEY=
WRAITH_MUTATION_MODEL=gpt-5.4-mini
NVD_API_KEY=
WRAITH_NUCLEI_BIN=
WRAITH_MANAGED_NUCLEI_BIN=
WRAITH_NUCLEI_TEMPLATE_DIR=
WRAITH_NUCLEI_TRUST_CONFIG=
